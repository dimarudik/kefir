<configuration>
    <!-- Логирование в консоль для тестов -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Отдельный файл для логов тестов -->
    <appender name="TEST_FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/tests.log</file>
        <append>false</append> <!-- Каждый прогон тестов затирает старый лог тестов -->
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Настройка уровней -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="TEST_FILE" />
    </root>
</configuration>
